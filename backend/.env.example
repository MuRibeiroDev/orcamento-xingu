# Banco de dados.
# Local (padrão): SQLite em arquivo. Para produção, use a string do Supabase/Postgres
# (instale antes o driver: pip install -r requirements-postgres.txt):
# DATABASE_URL=postgresql+psycopg://usuario:senha@host:5432/postgres
DATABASE_URL=sqlite:///./orcamentos.db

# Credenciais do usuário único do sistema
ADMIN_USER=glaucia
ADMIN_PASSWORD=troque-esta-senha

# Chave para assinar os tokens JWT (gere uma aleatória em produção)
SECRET_KEY=troque-por-uma-chave-secreta-aleatoria

# Origens permitidas para o frontend (CORS), separadas por vírgula
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
